<Window x:Class="KursT1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализ цветовых сегментов" Height="700" Width="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Загрузить шаблон" Click="LoadTemplate_Click" 
                    Margin="5" Padding="10,5" Width="120"/>
            <Button Content="Загрузить рисунок" Click="LoadDrawing_Click" 
                    Margin="5" Padding="10,5" Width="120"/>
            <Button Content="Экспорт" Click="Export_Click" 
                    Margin="5" Padding="10,5" Width="80"/>
            <Button Content="Очистить" Click="Clear_Click" 
                    Margin="5" Padding="10,5" Width="80"/>
        </StackPanel>

        <!-- Две колонки: рисунок и таблица -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Изображение -->
            <GroupBox Grid.Column="0" Header="Рисунок" Margin="5">
                <Image x:Name="DrawingImage" Stretch="Uniform" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </GroupBox>

            <!-- Таблица результатов -->
            <GroupBox Grid.Column="1" Header="Результаты анализа" Margin="5">
                <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Сегмент" Binding="{Binding SegmentName}" Width="*"/>
                        <DataGridTextColumn Header="Цвет" Binding="{Binding DominantClusterName}" Width="*"/>
                        <DataGridTextColumn Header="Процент" Binding="{Binding DominantClusterPercentage, StringFormat=F1}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- Статус -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" Text="Готов к работе" FontWeight="Bold"/>
        </StatusBar>
    </Grid>
</Window>