<Window x:Class="KursT1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализ рисуночного теста (K-Modes)" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопки загрузки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="📁 Загрузить ШАБЛОН" 
                    Click="LoadTemplate_Click"
                    FontSize="14" Padding="15,8"
                    Margin="0,0,10,0"
                    Background="#FFE0E0"/>

            <Button Content="🎨 Загрузить РИСУНОК" 
                    Click="LoadDrawing_Click"
                    FontSize="14" Padding="15,8"
                    Background="#E0E0FF"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="1" x:Name="StatusText" 
                   FontSize="14" Margin="0,10,0,15"
                   TextWrapping="Wrap"/>

        <!-- Основное содержимое -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: изображения -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Шаблон -->
                <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ШАБЛОН" 
                                   FontSize="12" FontWeight="Bold" 
                                   Margin="5" HorizontalAlignment="Center"/>
                        <Image x:Name="TemplateImage" 
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Рисунок пользователя -->
                <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="РИСУНОК ПОЛЬЗОВАТЕЛЯ" 
                                   FontSize="12" FontWeight="Bold" 
                                   Margin="5" HorizontalAlignment="Center"/>
                        <Image x:Name="DrawingImage" 
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Правая панель: результаты -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Таблица результатов -->
                    <TextBlock Text="📋 Результаты анализа по зонам" 
                               FontSize="16" FontWeight="Bold" 
                               Margin="0,0,0,10"/>

                    <DataGrid x:Name="ResultsGrid" 
                              AutoGenerateColumns="False" 
                              Height="550"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              RowHeight="60">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding SegmentId}" Width="40"/>
                            <DataGridTextColumn Header="Зона" Binding="{Binding SegmentName}" Width="130"/>

                            <DataGridTemplateColumn Header="Доминирующий кластер" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DominantColorWithPercent}" 
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding DominantClusterName}" 
                                                       FontSize="10" Foreground="Gray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="%" Binding="{Binding DominantClusterPercentage, StringFormat=F1}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15,0,0">
            <Button Content="💾 Сохранить отчёт" 
                    Click="SaveReport_Click"
                    FontSize="14" Padding="15,8"
                    Margin="0,0,10,0"/>

            <Button Content="🗑️ Очистить" 
                    Click="Clear_Click"
                    FontSize="14" Padding="15,8"/>
        </StackPanel>
    </Grid>
</Window>